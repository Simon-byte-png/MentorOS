# MentorOS environment placeholders.
# Do not add real secrets to this file.

# apps/web
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# WARNING: 仅限本地开发使用，绝不能在 Vercel Production 环境中设置为 true。
# Production 下代码层面已强制禁用 dev bypass，即使误配 true 也不会生效。
NEXT_PUBLIC_ALLOW_DEV_BYPASS=false

# Supabase auth and database.
# NEXT_PUBLIC_SUPABASE_URL / NEXT_PUBLIC_SUPABASE_ANON_KEY are safe for browser and SSR auth.
# SUPABASE_SERVICE_ROLE_KEY is server-only; never expose it to client components.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# packages/ai - DeepSeek provider config.
ENABLE_REAL_LLM=false
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_HIGH_QUALITY_MODEL=deepseek-v4-pro

# L1 chat gate config.
# auto: 有 ENABLE_REAL_LLM=true 且有 DEEPSEEK_API_KEY 时走 deepseek，否则走 mock。
# 也可显式设置为 mock 或 deepseek；deepseek 缺配置时会直接报错。
MENTOROS_CHAT_PROVIDER=auto
MENTOROS_COST_SENSITIVE=true
MENTOROS_QUALITY_MODE=false
MENTOROS_DAILY_MESSAGE_LIMIT=20
